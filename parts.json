  "固鎖_刃": [
    {
      "刃": "1",
      "說明": "賽場/實用的熱選，1刃跟水滴狀的外型，很適合平衡戰刃的偏重與透過突出的刃強化攻擊力度。很適合給持久型陀螺使用，也因為外型的緣故，有機率從失分區彈出來復活。"
    },
    {
      "刃": "2",
      "說明": "雖然可以平衡配重，容易撞擊時卡到，易爆開，不推薦。"
    },
    {
      "刃": "3",
      "說明": "適合戰刃是三枚刃的陀螺搭配，有三點穩定的效果兼具攻擊功能，但容易撞擊時卡到，易爆開，不建議輕易使用。"
    },
    {
      "刃": "4",
      "說明": "增加離心與穩定，容易撞擊時卡到，易爆開，不推薦。"
    },
    {
      "刃": "5",
      "說明": "刃與刃之間的間距變小，有真正的實質的離心力與攻擊功能，左迴旋陀螺專武。"
    },
    {
      "刃": "6",
      "說明": "有鎖血且較為實用固鎖，9刃的下位替代版，持久跟攻擊兼顧。"
    },
    {
      "刃": "7",
      "說明": "側緣較為厚，整體較厚，除了沒有尾速滾動外，兼具6刃的特色與單數刃也更適合調整陀螺偏重，達到更持久的效果。"
    },
    {
      "刃": "8",
      "說明": "防禦持久型的重型陀螺使用，8刃形狀也兼具不錯的防撞能力，但是有可能勾到爆開，需要配合低位軸心搭配。"
    },
    {
      "刃": "9",
      "說明": "賽場/實用的熱選，刃較小抗爆開、外型面積較小，重心內縮增加持久、互撞換血消耗小，兼具尾速滾動，缺點就是比較貴。"
    },
    {
      "刃": "M",
      "說明": "金屬系列，雖然較重，只有5刃且容易爆開，可惜變成冷門固鎖。"
    }
  ],
  "固鎖_高度": [
    {
      "高度": "50",
      "說明": "解放1-60的可怕零件，大幅提高遇到2攻或3攻陀螺隊五的兇手。\n搭配高軸心平衡整體陀螺高度，或是用來組建低重心高位移的刺殺陀螺的低位系列。"
    },
    {
      "高度": "60",
      "說明": "一般基礎款的固鎖高度。"
    },
    {
      "高度": "70",
      "說明": "適合用大重量陀螺進行壓制策略時用的高位系列"
    },
    {
      "高度": "80",
      "說明": "由於高過頭，等於露出脖子要人來砍，所以目前完全不適用，但適合陰親戚家的小孩"
    },
    {
      "高度": "5結尾",
      "說明": "例如55、65、85等，這類尾數除了高度比常規多5外，固鎖設計的咬合力也較強較緊，但是因為是塑膠製品的緣故，導致相當不耐撞，一旦爆開過後就會鬆掉，而且影響的除了固鎖外，連戰刃的咬合都可能被影響到。目前比較常用的是時鐘幻象上。"
    }
  ]
}